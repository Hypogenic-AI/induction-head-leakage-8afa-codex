{"type":"item.started","item":{"id":"item_41","type":"command_execution","command":"/bin/bash -lc \"pwd\nsource .venv/bin/activate && python - <<'PY'\nimport arxiv, re, json, requests\nfrom pathlib import Path\nroot = Path('/workspaces/induction-head-leakage-8afa-codex')\npapers_dir = root / 'papers'\nselected = {\n    '2209.11895': 'in_context_learning_and_induction_heads',\n    '2407.07011': 'induction_heads_pattern_matching_icl',\n    '2402.13055': 'identifying_semantic_induction_heads',\n    '2505.13514': 'induction_head_toxicity_repetition_curse',\n    '2404.10859': 'forcing_diffuse_distributions',\n    '2302.04460': 'bag_of_tricks_training_data_extraction',\n    '2305.16157': 'training_data_extraction_survey',\n    '2407.17817': 'demystifying_verbatim_memorization',\n    '2210.17546': 'preventing_verbatim_memorization_false_privacy',\n    '2107.06499': 'deduplicating_training_data_makes_lms_better',\n}\nclient = arxiv.Client()\nrecords = []\nheaders = {'User-Agent': 'codex-resource-finder/1.0'}\nfor result in client.results(arxiv.Search(id_list=list(selected.keys()))):\n    arxiv_id = result.get_short_id().split('v')[0]\n    slug = selected[arxiv_id]\n    filename = f\\\"{arxiv_id}_{slug}.pdf\\\"\n    path = papers_dir / filename\n    pdf_url = result.pdf_url + '.pdf'\n    if not path.exists():\n        r = requests.get(pdf_url, headers=headers, timeout=60)\n        r.raise_for_status()\n        path.write_bytes(r.content)\n    records.append({\n        'id': arxiv_id,\n        'title': result.title,\n        'authors': [a.name for a in result.authors],\n        'year': result.published.year,\n        'published': result.published.isoformat(),\n        'updated': result.updated.isoformat(),\n        'summary': re.sub(r'\\\\s+', ' ', result.summary).strip(),\n        'pdf': filename,\n        'pdf_url': pdf_url,\n        'entry_id': result.entry_id,\n        'primary_category': result.primary_category,\n        'categories': result.categories,\n    })\nrecords.